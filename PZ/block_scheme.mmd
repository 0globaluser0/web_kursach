flowchart TD
    A["Запуск start_cryptotrade.bat или backend.py"] --> B["Инициализация SQLite cryptotrade.db"]
    B --> C["Открытие index.html через локальный сервер"]
    C --> D{"Пользователь вошел?"}
    D -- "Нет" --> E["Ввод email и пароля или регистрация"]
    E --> F["Запрос состояния через /api/state"]
    F --> G{"Данные корректны?"}
    G -- "Нет" --> E
    G -- "Да" --> H["Сохранение локальной сессии браузера"]
    D -- "Да" --> I["Открытие dashboard.html"]
    H --> I
    I --> J["Загрузка рынка, портфеля и истории из SQLite через API"]
    J --> K["Просмотр рынка и графиков"]
    K --> L["Запрос свечей через /api/klines"]
    L --> M{"Свечи получены?"}
    M -- "Да" --> N["Построение TradingView-графика"]
    M -- "Нет" --> O["Построение fallback-графика по price_history"]
    N --> P["Выбор актива на странице trade.html"]
    O --> P
    P --> Q["Ввод количества и типа операции"]
    Q --> R{"Средств или монет достаточно?"}
    R -- "Нет" --> S["Сообщение об ошибке"]
    S --> Q
    R -- "Да" --> T["Обновление users и wallets"]
    T --> U["Создание записи transactions"]
    U --> V["Сохранение изменений в SQLite через POST /api/state"]
    V --> W["Просмотр portfolio.html и history.html"]
